{
  "id": "weather",
  "name": "Weather",
  "description": "Current weather for any city using wttr.in",
  "version": "1.0.0",
  "icon": "🌤️",
  "allowedCommands": [],
  "network": true,
  "cli": {
    "summary": "Current weather for any city (wttr.in)",
    "events": [
      {
        "id": "set_city",
        "description": "Change city and reload weather (payload: {\"city\":\"Grodno\"})"
      },
      {
        "id": "submit_city",
        "description": "Search weather for a city (payload: {\"value\":\"Berlin\"})"
      },
      {
        "id": "submit_city_btn",
        "description": "Same as submit_city using the Go button"
      },
      {
        "id": "city_input_change",
        "description": "City text field changed (payload: {\"value\":\"...\"})"
      }
    ],
    "read": {
      "state": "jsr app:state weather — tempC, city, humidity, windKmph",
      "snapshot": "jsr app:snapshot weather — full render JSON tree"
    },
    "examples": [
      "jsr app:run weather",
      "jsr app:execute weather set_city '{\"city\":\"Moscow\"}'",
      "jsr app:execute weather submit_city '{\"value\":\"Moscow\"}'",
      "jsr app:state weather"
    ]
  }
}
