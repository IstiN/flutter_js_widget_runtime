#!/usr/bin/env bash
# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  QUALITY GATE — DO NOT LOWER THESE THRESHOLDS WITHOUT TEAM APPROVAL       ║
# ║  Every commit must pass these gates.                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝
#
# Pre-commit hook: file-size + duplication + coverage ratchet + Flutter tests.
# To skip (emergency only): git commit --no-verify

set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

unset GIT_DIR GIT_INDEX_FILE GIT_WORK_TREE 2>/dev/null || true

# ═══════════════════════════════════════════════════════════════════════════
# 1. FILE SIZE GUARD
# ═══════════════════════════════════════════════════════════════════════════
MAX_LINES=1500
VIOLATIONS=()

while IFS= read -r file; do
  case "$file" in
    *.dart)
      case "$file" in
        *.g.dart|*.freezed.dart|*.mocks.dart) continue ;;
      esac
      lines=$(wc -l < "$file")
      if (( lines > MAX_LINES )); then
        VIOLATIONS+=("  $file: $lines lines (max $MAX_LINES)")
      fi
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACM)

if ((${#VIOLATIONS[@]} > 0)); then
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — FILE SIZE                                       ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  echo "   Staged files exceed $MAX_LINES lines:"
  printf '%s\n' "${VIOLATIONS[@]}"
  echo ""
  echo "   Extract widgets / logic into smaller files, then retry."
  echo "   Use --no-verify to skip (NOT recommended)."
  exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════
# 2. CODE DUPLICATION GUARD
# ═══════════════════════════════════════════════════════════════════════════
DUP_THRESHOLD=1.5
if command -v jscpd >/dev/null 2>&1; then
  echo "🔍 Checking code duplication (threshold: < ${DUP_THRESHOLD}%)..."
  jscpd --config .jscpd.json --min-tokens 50 --min-lines 5 --reporters json --output /tmp/jscpd-precommit lib/ test/ >/dev/null 2>&1 || true
  DUP_PCT=$(python3 -c "
import json,sys
try:
    with open('/tmp/jscpd-precommit/jscpd-report.json') as f:
        d=json.load(f)
    print(d['statistics']['total']['percentage'])
except: print('0.0')
" 2>/dev/null || echo "0.0")
  if python3 -c "exit(0 if float('$DUP_PCT') < float('$DUP_THRESHOLD') else 1)" 2>/dev/null; then
    echo "✅ Duplication check OK ($DUP_PCT% < ${DUP_THRESHOLD}%)"
  else
    echo ""
    echo "╔═══════════════════════════════════════════════════════════════════════════╗"
    echo "║  ❌ QUALITY GATE FAILED — CODE DUPLICATION                                ║"
    echo "╚═══════════════════════════════════════════════════════════════════════════╝"
    echo "   Duplication: $DUP_PCT% (max ${DUP_THRESHOLD}%)"
    echo ""
    echo "   Run: jscpd --config .jscpd.json --min-tokens 50 --min-lines 5 lib/ test/"
    echo "   Extract shared helpers / widgets, then retry."
    echo "   Use --no-verify to skip (NOT recommended)."
    exit 1
  fi
fi

# ═══════════════════════════════════════════════════════════════════════════
# 3. COVERAGE RATCHET
# ═══════════════════════════════════════════════════════════════════════════
COVERAGE_BASELINE=37.0
COVERAGE_TARGET=50.0

if [ ! -f coverage/lcov.info ]; then
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — NO COVERAGE DATA                                ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  echo "   coverage/lcov.info is missing."
  echo "   Run: flutter test --coverage"
  echo "   Then stage the updated coverage/lcov.info and retry."
  exit 1
fi

COVERAGE_PCT=$(python3 -c "
import sys
with open('coverage/lcov.info','r') as f:
    content=f.read()
files=content.split('SF:')
total_found=0; total_hit=0
for sec in files[1:]:
    for line in sec.strip().split('\n')[1:]:
        if line.startswith('DA:'):
            total_found+=1
            if int(line[3:].split(',')[1])>0:
                total_hit+=1
if total_found>0:
    print(f'{(total_hit/total_found)*100:.1f}')
else:
    print('0.0')
" 2>/dev/null || echo "0.0")

if python3 -c "exit(0 if float('$COVERAGE_PCT') >= float('$COVERAGE_BASELINE') else 1)" 2>/dev/null; then
  echo "✅ Coverage ratchet OK ($COVERAGE_PCT% >= ${COVERAGE_BASELINE}%)"
  if python3 -c "exit(0 if float('$COVERAGE_PCT') >= float('$COVERAGE_TARGET') else 1)" 2>/dev/null; then
    echo "   🏆 Coverage target ${COVERAGE_TARGET}% reached — excellent!"
  else
    echo "   🎯 Coverage target: ${COVERAGE_TARGET}% (current: $COVERAGE_PCT%)"
  fi
else
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — TEST COVERAGE                                   ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  echo "   Coverage: $COVERAGE_PCT% (baseline ${COVERAGE_BASELINE}%)"
  echo ""
  echo "   Add tests for changed code, then retry."
  echo "   Run: flutter test --coverage"
  echo "   Use --no-verify to skip (NOT recommended)."
  exit 1
fi

# ═══════════════════════════════════════════════════════════════════════════
# 4. TESTS
# ═══════════════════════════════════════════════════════════════════════════
echo "🧪 Running tests before commit..."
TEST_LOG="/tmp/js_widget_runtime-precommit-tests.log"
rm -f "$TEST_LOG"

if flutter test > "$TEST_LOG" 2>&1; then
  echo "✅ All tests passed"
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ✅ ALL QUALITY GATES PASSED — COMMIT APPROVED                            ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
else
  echo ""
  echo "╔═══════════════════════════════════════════════════════════════════════════╗"
  echo "║  ❌ QUALITY GATE FAILED — TESTS                                           ║"
  echo "╚═══════════════════════════════════════════════════════════════════════════╝"
  echo "   Fix failing tests or use --no-verify to skip (NOT recommended)."
  echo ""
  echo "   Full test log: $TEST_LOG"
  echo "   ───────────────────────────────────────────────────────────────────────"
  grep -E "FAILED|Some tests failed|All tests passed" "$TEST_LOG" || true
  tail -n 80 "$TEST_LOG"
  echo "   ───────────────────────────────────────────────────────────────────────"
  exit 1
fi
